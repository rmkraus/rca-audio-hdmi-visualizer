[Unit]
Description=Fullscreen now-playing overlay
After=display-manager.service rca-cavasik-kiosk.service rca-now-playing.service
Wants=rca-now-playing.service

[Service]
Type=simple
EnvironmentFile=-/etc/rca-hdmi-visualizer.env
ExecStart=/usr/local/bin/start-now-playing-overlay
Restart=always
RestartSec=5

[Install]
WantedBy=graphical.target
