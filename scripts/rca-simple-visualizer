#!/usr/bin/env python3
import audioop
import math
import os
import pwd
import struct
import subprocess
from tkinter import BOTH, Canvas, Tk


def env_file(path):
    vals = {}
    try:
        with open(path) as fh:
            for raw in fh:
                line = raw.strip()
                if not line or line.startswith('#') or '=' not in line:
                    continue
                k, v = line.split('=', 1)
                vals[k.strip()] = v.strip().strip('"').strip("'")
    except IOError:
        pass
    vals.update(os.environ)
    return vals


def user_runtime(user):
    uid = subprocess.check_output(['id', '-u', user]).decode().strip()
    return {
        'XDG_RUNTIME_DIR': '/run/user/%s' % uid,
        'DBUS_SESSION_BUS_ADDRESS': 'unix:path=/run/user/%s/bus' % uid,
    }


def current_username():
    try:
        return pwd.getpwuid(os.geteuid()).pw_name
    except Exception:
        return ''


def clamp(value, low=0.0, high=1.0):
    return max(low, min(high, value))


class Visualizer:
    def __init__(self):
        self.cfg = env_file('/etc/rca-hdmi-visualizer.env')
        self.user = self.cfg.get('VISUALIZER_USER', '')
        self.source = self.cfg.get('RECOGNITION_SOURCE') or self.cfg.get('SOURCE_MATCH') or ''
        self.rate = int(self.cfg.get('RECOGNITION_SAMPLE_RATE', '44100') or '44100')
        self.channels = int(self.cfg.get('RECOGNITION_CHANNELS', '1') or '1')
        self.chunk_frames = 4096
        self.samples = [0.0] * 96
        self.level = 0.0
        self.peak = 0.0
        self.noise_floor = float(self.cfg.get('VISUALIZER_NOISE_FLOOR', '220') or '220')
        self.scale = float(self.cfg.get('VISUALIZER_SCALE', '2600') or '2600')
        self.proc = None
        self.last_error = ''

        self.root = Tk()
        self.root.title('RCA Audio Visualizer')
        self.root.configure(bg='black')
        self.root.attributes('-fullscreen', True)
        self.root.bind('<Escape>', lambda _e: self.root.destroy())
        self.root.bind('q', lambda _e: self.root.destroy())
        self.canvas = Canvas(self.root, bg='black', highlightthickness=0)
        self.canvas.pack(fill=BOTH, expand=True)
        self.start_capture()

    def start_capture(self):
        if self.proc and self.proc.poll() is None:
            return
        cmd = ['parec', '--format=s16le', '--rate=%d' % self.rate, '--channels=%d' % self.channels]
        if self.source:
            cmd.insert(1, '--device=%s' % self.source)

        env = os.environ.copy()
        if self.user:
            env.update(user_runtime(self.user))

        if self.user and current_username() != self.user:
            run_env = ['env'] + ['%s=%s' % (k, v) for k, v in user_runtime(self.user).items()]
            cmd = ['runuser', '-u', self.user, '--'] + run_env + cmd

        try:
            self.proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, env=env)
            self.last_error = ''
        except Exception as exc:
            self.proc = None
            self.last_error = str(exc)

    def read_audio(self):
        if not self.proc or self.proc.poll() is not None:
            if self.proc and self.proc.stderr:
                try:
                    self.last_error = self.proc.stderr.read().decode('utf-8', 'replace')[-160:]
                except Exception:
                    pass
            self.start_capture()
            return []
        wanted = self.chunk_frames * self.channels * 2
        data = self.proc.stdout.read(wanted)
        if not data:
            return []
        if self.channels > 1:
            data = audioop.tomono(data, 2, 0.5, 0.5)
        count = len(data) // 2
        if not count:
            return []
        return struct.unpack('<%dh' % count, data[:count * 2])

    def audio_to_columns(self, samples, columns):
        if not samples:
            return [0.0] * columns, 0.0
        avg_abs = sum(abs(x) for x in samples) / float(len(samples))
        level = clamp((avg_abs - self.noise_floor) / max(self.scale, 1.0))

        stride = max(1, len(samples) // columns)
        vals = []
        for idx in range(columns):
            start = idx * stride
            chunk = samples[start:start + stride]
            if not chunk:
                vals.append(0.0)
                continue
            # Peak-minus-noise tracks actual waveform energy in this slice.
            peak = max(abs(x) for x in chunk)
            vals.append(clamp((peak - self.noise_floor) / max(self.scale * 3.0, 1.0)))
        return vals, level

    def tick(self):
        samples = self.read_audio()
        new_samples, new_level = self.audio_to_columns(samples, len(self.samples))
        # Smooth enough to stop random pumping, but not so much that beats vanish.
        self.samples = [old * 0.55 + new * 0.45 for old, new in zip(self.samples, new_samples)]
        self.level = self.level * 0.80 + new_level * 0.20
        self.peak = max(self.level, self.peak * 0.96)
        self.draw()
        self.root.after(33, self.tick)

    def draw(self):
        w = max(self.canvas.winfo_width(), 1)
        h = max(self.canvas.winfo_height(), 1)
        self.canvas.delete('all')
        n = len(self.samples)
        gap = 4
        bar_w = max(3, (w - gap * (n + 1)) // n)
        mid = int(h * 0.52)
        max_h = int(h * 0.33)

        for y in range(int(h * 0.18), int(h * 0.86), max(28, h // 18)):
            self.canvas.create_line(0, y, w, y, fill='#020b08')
        self.canvas.create_line(0, mid, w, mid, fill='#063024')

        for i, val in enumerate(self.samples):
            # A small floor keeps the UI visible without pretending silence is loud.
            shaped = math.sqrt(max(0.012, val))
            bh = max(3, int(max_h * shaped))
            x0 = gap + i * (bar_w + gap)
            x1 = x0 + bar_w
            brightness = int(70 * clamp(val * 2.5))
            color = '#%02x%02x%02x' % (35 + brightness, 135 + brightness, 105 + brightness)
            self.canvas.create_rectangle(x0, mid - bh, x1, mid + bh, fill=color, outline='')

        meter_w = int(w * 0.62)
        meter_h = max(8, h // 120)
        meter_x = (w - meter_w) // 2
        meter_y = int(h * 0.84)
        self.canvas.create_rectangle(meter_x, meter_y, meter_x + meter_w, meter_y + meter_h, fill='#06120f', outline='#12382d')
        self.canvas.create_rectangle(
            meter_x,
            meter_y,
            meter_x + int(meter_w * clamp(self.level)),
            meter_y + meter_h,
            fill='#4de0a3',
            outline='',
        )
        self.canvas.create_rectangle(
            meter_x + int(meter_w * clamp(self.peak)),
            meter_y - 4,
            meter_x + int(meter_w * clamp(self.peak)) + 2,
            meter_y + meter_h + 4,
            fill='#d7ffe8',
            outline='',
        )

        self.canvas.create_text(w // 2, int(h * 0.10), text='musicman', fill='#606060', font=('DejaVu Sans', 24))
        label = 'input %d%%' % int(clamp(self.level) * 100)
        if self.last_error:
            label += '  capture: %s' % self.last_error.strip().replace('\n', ' ')
        self.canvas.create_text(w // 2, int(h * 0.88), text=label, fill='#707070', font=('DejaVu Sans', 18))

    def run(self):
        self.root.after(100, self.tick)
        self.root.mainloop()


if __name__ == '__main__':
    Visualizer().run()
