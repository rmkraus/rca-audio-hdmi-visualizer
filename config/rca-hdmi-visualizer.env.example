VISUALIZER_USER=pi

# Auto-detected by install.sh. Values: raspberry-pi, jetson-nano, generic.
PLATFORM=generic

# Cavasik Flatpak application ID.
CAVASIK_APP_ID=io.github.TheWisker.Cavasik

# Optional visualizer command override. Leave empty to run the Cavasik Flatpak.
# Example fallback if Cavasik is unavailable: VISUALIZER_COMMAND="xterm -fullscreen -e cava"
VISUALIZER_COMMAND=

# Text matched against pactl source descriptions/names to select the USB RCA capture interface.
# Leave empty to use the current default source.
SOURCE_MATCH=iRig

# Text matched against pactl sink descriptions/names to select HDMI audio output.
# Leave empty to use the current default sink.
SINK_MATCH=hdmi

# Requested audio loopback latency.
LOOPBACK_LATENCY_MSEC=25

# Window title/class text for fullscreening Cavasik with wmctrl/xdotool.
WINDOW_MATCH=Cavasik

# Seconds to wait for desktop/audio readiness during boot.
STARTUP_TIMEOUT=60

# AcoustID now-playing recognition. Requires ACOUSTID_CLIENT_KEY in
# /etc/rca-hdmi-visualizer.secrets. Disabled by default so installs do not
# send audio fingerprints until explicitly configured.
RECOGNITION_ENABLED=false
RECOGNITION_SOURCE=
RECOGNITION_SAMPLE_SECONDS=45
RECOGNITION_INTERVAL_SECONDS=30
RECOGNITION_COOLDOWN_SECONDS=75
RECOGNITION_MIN_SCORE=0.80
RECOGNITION_MIN_RMS=150
RECOGNITION_KEEP_LAST_ON_MISS=true
RECOGNITION_SAMPLE_RATE=44100
RECOGNITION_CHANNELS=2

# Optional snippet-oriented fallback. AcoustID is designed for whole-track file
# matching and can miss live vinyl snippets; this fallback uses a Shazam-style
# recognizer if its Python venv is installed.
SHAZAM_FALLBACK_ENABLED=false
NOW_PLAYING_STATE=/var/lib/rca-hdmi-visualizer/now-playing.json

# Fullscreen now-playing overlay. OVERLAY_ALPHA<1 lets some visualization show
# through the overlay. Set OVERLAY_SHOW_UNRECOGNIZED=true for debugging.
OVERLAY_ALPHA=0.78
OVERLAY_POLL_MSEC=1000
OVERLAY_SHOW_UNRECOGNIZED=false
OVERLAY_WINDOW_MATCH=Now Playing
