VISUALIZER_USER=pi

# Auto-detected by install.sh. Values: raspberry-pi, jetson-nano, generic.
PLATFORM=generic

# Text matched against pactl source descriptions/names to select the USB RCA capture interface.
# Leave empty to use the current default source.
SOURCE_MATCH=iRig

# Text matched against pactl sink descriptions/names to select HDMI audio output.
# Leave empty to use the current default sink.
SINK_MATCH=hdmi

# Requested audio loopback latency.
LOOPBACK_LATENCY_MSEC=25

# Seconds to wait for desktop/audio readiness during boot.
STARTUP_TIMEOUT=60

# Now-playing recognition. Disabled by default so installs do not make network
# requests until explicitly configured. Uses a Shazam-style snippet recognizer.
RECOGNITION_ENABLED=false
RECOGNITION_SOURCE=
RECOGNITION_SAMPLE_SECONDS=12
RECOGNITION_MIN_RMS=150
RECOGNITION_SAMPLE_RATE=44100
RECOGNITION_CHANNELS=2
# Quiet windows before the overlay reports Stopped.
RECOGNITION_SILENCE_WINDOWS_TO_STOP=1
# No-match windows before pausing lookups briefly.
RECOGNITION_NO_MATCH_LIMIT=3
RECOGNITION_NO_MATCH_BACKOFF_SECONDS=30
# If Shazam requests exceed this per-minute count, pause lookups for 10 minutes.
RECOGNITION_RATELIMIT_REQUESTS_PER_MIN=5
RECOGNITION_RATELIMIT_BACKOFF_SECONDS=600
# After a recognized track, do not check again until estimated progress reaches this percent.
RECOGNITION_PROGRESS_RESUME_PERCENT=100
# Never wait longer than this between checks, even for long tracks.
RECOGNITION_MAX_RECHECK_WAIT_SECONDS=150
# If track length is unavailable, hide progress and check again after this delay.
RECOGNITION_MISSING_DURATION_RECHECK_SECONDS=60
# Add this many seconds to Shazam's matched sample offset for display/check timing.
RECOGNITION_PROGRESS_OFFSET_PADDING_SECONDS=5
NOW_PLAYING_STATE=/var/lib/rca-hdmi-visualizer/now-playing.json

# Fullscreen now-playing display. Set OVERLAY_SHOW_UNRECOGNIZED=true for debugging.
OVERLAY_ALPHA=0.78
OVERLAY_POLL_MSEC=1000
OVERLAY_SHOW_UNRECOGNIZED=false
OVERLAY_WINDOW_MATCH=Now Playing
